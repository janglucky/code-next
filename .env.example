# Provider mode for local CLI runs: openai or byok.
# If this is openai but OPENAI_API_KEY is empty, the CLI falls back to BYOK when BYOK_API_KEY is set.
AGENT_PROVIDER=openai

# OpenAI mode.
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-5.5
OPENAI_API_MODE=responses
OPENAI_REASONING_EFFORT=low

# BYOK mode.
BYOK_API_KEY=
BYOK_BASE_URL=
BYOK_MODEL=
BYOK_API_MODE=chat
BYOK_REASONING_EFFORT=off

# Agent runtime.
AGENT_MAX_STEPS=8
AGENT_REQUEST_TIMEOUT_MS=300000
AGENT_MAX_RETRIES=2

# Proxy for model API calls.
# If empty, the CLI will use HTTPS_PROXY / HTTP_PROXY / ALL_PROXY when present.
AGENT_PROXY_URL=
# Set AGENT_PROXY=off to disable proxy detection.
AGENT_PROXY=
